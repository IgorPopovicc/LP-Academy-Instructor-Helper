{
  "manifest_version": 3,
  "name": "Udemy Q&A Extractor",
  "description": "A productivity tool for Udemy instructors that scans course Q&A discussions, identifies unanswered and unresolved questions, and enables fast exporting of data to streamline daily instructor workflows.",
  "version": "1.0.1",
  "permissions": ["storage", "scripting", "tabs", "activeTab"],
  "host_permissions": [
    "https://www.udemy.com/*",
    "http://localhost:4200/*",
    "https://*.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.udemy.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://localhost:4200/*",
        "https://*.vercel.app/*"
      ],
      "js": ["app-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected-sniffer.js", "assets/lpa.png", "assets/lpa.ico"],
      "matches": ["https://www.udemy.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/lpa.png",
      "32": "assets/lpa.png",
      "48": "assets/lpa.png",
      "128": "assets/lpa.png"
    }
  },
  "icons": {
    "16": "assets/lpa.png",
    "32": "assets/lpa.png",
    "48": "assets/lpa.png",
    "128": "assets/lpa.png"
  }
}
